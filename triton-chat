#!/usr/bin/env python3
"""Interactive chat REPL for Triton Inference Server via the OpenAI-compatible frontend."""

import os
import sys

from openai import OpenAI

TRITON_OPENAI_BASE = os.environ.get("TRITON_OPENAI_BASE", "http://localhost:9000/v1")
TRITON_API_KEY = os.environ.get("TRITON_API_KEY", "EMPTY")
TRITON_MODEL = os.environ.get("TRITON_MODEL", "")
TRITON_SYSTEM_PROMPT = os.environ.get(
    "TRITON_SYSTEM_PROMPT", "You are a helpful assistant."
)

HELP_TEXT = """\
Commands:
  /clear            Clear conversation history
  /model [name]     Show or change the model
  /system [prompt]  Show or change the system prompt
  /help             Show this help
  /quit             Exit the chat"""


def main():
    from rich.console import Console
    from rich.markdown import Markdown

    console = Console()
    client = OpenAI(base_url=TRITON_OPENAI_BASE, api_key=TRITON_API_KEY)

    model = TRITON_MODEL
    if not model:
        console.print("[red]TRITON_MODEL is not set.[/red]")
        console.print("Set it via: export TRITON_MODEL=<model_name>")
        sys.exit(1)

    system_prompt = TRITON_SYSTEM_PROMPT
    messages = []

    console.print(f"[bold]triton-chat[/bold] connected to [cyan]{TRITON_OPENAI_BASE}[/cyan]")
    console.print(f"Model: [green]{model}[/green]")
    console.print("Type [bold]/help[/bold] for commands, [bold]/quit[/bold] to exit.\n")

    while True:
        try:
            user_input = input("you> ").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\nBye!")
            break

        if not user_input:
            continue

        # Slash commands
        if user_input.startswith("/"):
            cmd, _, arg = user_input[1:].partition(" ")
            cmd = cmd.lower()
            arg = arg.strip()

            if cmd in ("quit", "exit"):
                console.print("Bye!")
                break
            elif cmd == "help":
                console.print(HELP_TEXT)
            elif cmd == "clear":
                messages.clear()
                console.print("[dim]Conversation cleared.[/dim]")
            elif cmd == "model":
                if arg:
                    model = arg
                    console.print(f"Model set to [green]{model}[/green]")
                else:
                    console.print(f"Model: [green]{model}[/green]")
            elif cmd == "system":
                if arg:
                    system_prompt = arg
                    console.print(f"System prompt set to: [yellow]{system_prompt}[/yellow]")
                else:
                    console.print(f"System prompt: [yellow]{system_prompt}[/yellow]")
            else:
                console.print(f"[red]Unknown command: /{cmd}[/red]")
            continue

        messages.append({"role": "user", "content": user_input})

        request_messages = [{"role": "system", "content": system_prompt}] + messages

        try:
            stream = client.chat.completions.create(
                model=model,
                messages=request_messages,
                stream=True,
            )

            chunks = []
            for chunk in stream:
                delta = chunk.choices[0].delta
                if delta.content:
                    chunks.append(delta.content)

            response_text = "".join(chunks)
            messages.append({"role": "assistant", "content": response_text})
            console.print()
            console.print(Markdown(response_text))
            console.print()

        except KeyboardInterrupt:
            console.print("\n[dim]Generation interrupted.[/dim]")
            messages.pop()
        except Exception as e:
            console.print(f"\n[red]Error: {e}[/red]")
            messages.pop()


if __name__ == "__main__":
    main()
